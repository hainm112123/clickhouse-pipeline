            "uid": "ClickHouse"
          },
          "format": 0,
          "queryType": "sql",
          "rawSql": "SELECT event_time, round(query_duration_ms / 1000, 2) as duration_sec, round(ProfileEvents['OSCPUTimeNano'] / (query_duration_ms * 1000000 + 1) * 100, 2) as peak_cpu_pct, written_rows, round(written_rows / (query_duration_ms / 1000 + 0.001), 0) as rows_per_sec, memory_usage as peak_mem FROM system.query_log WHERE query LIKE 'INSERT INTO sensor_storage.%' AND type = 'QueryFinish' ORDER BY event_time ASC SETTINGS use_query_cache = 0",
