          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT \n    s.timestamp AS time,\n    s.P2 AS pm25,\n    s.P1 AS pm10,\n    b.temperature,\n    b.humidity\nFROM sensor_storage.sds011_data AS s\nASOF LEFT JOIN sensor_storage.bme280_data AS b \n    ON s.location = b.location AND s.timestamp >= b.timestamp\nWHERE s.timestamp >= '2026-04-17 00:00:00' AND s.timestamp < '2026-04-18 00:00:00'\nORDER BY s.timestamp ASC\nSETTINGS use_query_cache = 0",
