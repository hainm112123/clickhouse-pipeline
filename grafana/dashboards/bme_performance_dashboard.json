      "title": "Air Cleanse Events (High Humidity -> Low Dust)",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "queryType": "sql",
          "rawSql": "SELECT level, count() AS num_events FROM (SELECT windowFunnel(1800)(timestamp, humidity > 90, P2 < 15) AS level FROM (SELECT s.timestamp, b.humidity, s.P2 FROM sensor_storage.sds011_data AS s ASOF LEFT JOIN sensor_storage.bme280_data AS b ON s.location = b.location AND s.timestamp >= b.timestamp ORDER BY s.timestamp ASC)) GROUP BY level ORDER BY level SETTINGS use_query_cache = 0",
          "refId": "A"
        }
      ]
    }
