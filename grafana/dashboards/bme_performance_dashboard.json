      "title": "Sudden PM2.5 Spikes (>50%)",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "queryType": "sql",
          "rawSql": "SELECT * FROM (SELECT timestamp, P2 as pm25, lag(P2) OVER (ORDER BY timestamp ASC) as prev_pm25, round(abs(P2 - prev_pm25) / (prev_pm25 + 0.1) * 100, 2) AS percent_change FROM sensor_storage.sds011_data) WHERE prev_pm25 > 0 AND percent_change > 50 ORDER BY timestamp DESC LIMIT 20 SETTINGS use_query_cache = 0",
          "refId": "A"
        }
      ]
    },
